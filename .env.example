# Database — PostgreSQL via Neon (Vercel Storage)
# Vercel vult dit automatisch in als je Neon koppelt via het Vercel dashboard.
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"

# Min. 32 willekeurige tekens — VERPLICHT eigen waarde in productie.
# Genereer met:  node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
NEXTAUTH_SECRET=""

# Mollie — laat leeg voor DEMO-modus (betaling wordt gesimuleerd).
# Vul je Mollie API-key in (test_... of live_...) om echte betalingen te activeren.
# Mollie levert Bancontact, Payconiq, KBC/CBC en kaarten in één checkout.
MOLLIE_API_KEY=""

# Basis-URL van de site (voor Mollie redirect/webhook). In productie je echte domein (https://...).
APP_BASE_URL="http://localhost:3000"

# Admin-login (seed gebruikt deze). Wijzig ZEKER vóór productie.
ADMIN_EMAIL="owner@verdec.be"
ADMIN_PASSWORD="admin123"
